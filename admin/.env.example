# Copy this file to .env and fill in real values. Never commit the real .env file.

# PostgreSQL connection — Supabase gives you TWO different connection
# strings; you need both (see admin/README.md for exactly where to find
# each one in the Supabase dashboard: Project Settings → Database).

# 1) DATABASE_URL — the POOLED connection (port 6543, "Transaction" mode).
#    This is what the running app uses for every normal query.
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 2) DIRECT_URL — the DIRECT connection (port 5432, no pooler).
#    Only used when running `prisma migrate` — pooled connections can't run migrations.
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[YOUR-PASSWORD]@aws-0-xxxxx.pooler.supabase.com:5432/postgres"

# Session signing secret — generate a real one with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# How long a login session stays valid, in days
SESSION_MAX_AGE_DAYS=7

# Absolute or relative path to the uploads folder this app should write into
# (see /uploads at the project root)
UPLOADS_DIR="../uploads/media"
UPLOADS_PUBLIC_PATH="/uploads/media"

# Set to "production" when deploying for real
NODE_ENV="development"
